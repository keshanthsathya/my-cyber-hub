<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>KESHANTH SATHYA // SYSTEM ACCESS</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Share+Tech+Mono&family=Exo+2:wght@300;400;700&display=swap" rel="stylesheet">
<style>
/* ============================
   ROOT VARIABLES & RESET
   ============================ */
:root {
  --neon-purple: #b026ff;
  --neon-soft: #d070ff;
  --neon-glow: rgba(176,38,255,0.35);
  --neon-border: rgba(176,38,255,0.6);
  --bg-black: #020205;
  --bg-dark: #07050f;
  --bg-panel: rgba(10,5,20,0.85);
  --text-main: #e8deff;
  --text-dim: #7a6a9a;
  --text-mono: #a0ffa0;
  --accent-cyan: #00fff7;
  --accent-red: #ff2244;
  --grid-color: rgba(176,38,255,0.06);
  --font-hud: 'Orbitron', monospace;
  --font-mono: 'Share Tech Mono', monospace;
  --font-body: 'Exo 2', sans-serif;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth;overflow-x:hidden}
body{
  background:var(--bg-black);
  color:var(--text-main);
  font-family:var(--font-body);
  cursor:none;
  overflow-x:hidden;
  min-height:100vh;
}
::selection{background:var(--neon-purple);color:#fff}
::-webkit-scrollbar{width:4px}
::-webkit-scrollbar-track{background:#000}
::-webkit-scrollbar-thumb{background:var(--neon-purple);border-radius:2px}

/* ============================
   CUSTOM CURSOR
   ============================ */
#cursor{
  position:fixed;width:18px;height:18px;
  border:1.5px solid var(--neon-purple);
  border-radius:2px;
  pointer-events:none;z-index:99999;
  transform:translate(-50%,-50%) rotate(45deg);
  transition:transform 0.08s,border-color 0.2s;
  mix-blend-mode:screen;
}
#cursor::after{
  content:'';position:absolute;top:50%;left:50%;
  width:4px;height:4px;
  background:var(--neon-purple);
  transform:translate(-50%,-50%);
  border-radius:50%;
  box-shadow:0 0 8px var(--neon-purple);
}
#cursor-trail{
  position:fixed;width:40px;height:40px;
  border:1px solid rgba(176,38,255,0.25);
  border-radius:2px;
  pointer-events:none;z-index:99998;
  transform:translate(-50%,-50%) rotate(45deg);
  transition:left 0.12s ease,top 0.12s ease;
}
#cursor.hover{
  transform:translate(-50%,-50%) rotate(45deg) scale(1.8);
  border-color:var(--accent-cyan);
  box-shadow:0 0 12px var(--accent-cyan);
}

/* ============================
   GLOBAL GRID BG
   ============================ */
.grid-bg{
  position:fixed;inset:0;pointer-events:none;z-index:0;
  background-image:
    linear-gradient(var(--grid-color) 1px,transparent 1px),
    linear-gradient(90deg,var(--grid-color) 1px,transparent 1px);
  background-size:60px 60px;
  opacity:0.7;
}
.scanline{
  position:fixed;inset:0;pointer-events:none;z-index:1;
  background:repeating-linear-gradient(
    0deg,
    transparent,transparent 2px,
    rgba(0,0,0,0.07) 2px,rgba(0,0,0,0.07) 4px
  );
  animation:scanmove 8s linear infinite;
}
@keyframes scanmove{
  0%{background-position:0 0}
  100%{background-position:0 100%}
}
.vignette{
  position:fixed;inset:0;pointer-events:none;z-index:2;
  background:radial-gradient(ellipse at center,transparent 55%,rgba(2,2,5,0.85) 100%);
}
/* Border glow */
.border-glow-top{
  position:fixed;top:0;left:0;right:0;height:2px;
  background:linear-gradient(90deg,transparent,var(--neon-purple),var(--neon-soft),var(--neon-purple),transparent);
  box-shadow:0 0 20px var(--neon-purple),0 0 40px var(--neon-glow);
  z-index:9999;animation:borderPulse 3s ease-in-out infinite;
}
.border-glow-bottom{
  position:fixed;bottom:0;left:0;right:0;height:2px;
  background:linear-gradient(90deg,transparent,var(--neon-purple),var(--neon-soft),var(--neon-purple),transparent);
  box-shadow:0 0 20px var(--neon-purple),0 0 40px var(--neon-glow);
  z-index:9999;animation:borderPulse 3s ease-in-out infinite 1.5s;
}
@keyframes borderPulse{
  0%,100%{opacity:0.6}50%{opacity:1;box-shadow:0 0 40px var(--neon-purple),0 0 80px var(--neon-glow)}
}

/* ============================
   COD 3D FLOATING ELEMENTS
   ============================ */
.cod-elements{
  position:fixed;inset:0;pointer-events:none;z-index:3;overflow:hidden;
}
.cod-obj{
  position:absolute;opacity:0.07;
  animation:floatObj 20s ease-in-out infinite;
  filter:drop-shadow(0 0 8px var(--neon-purple));
}
@keyframes floatObj{
  0%,100%{transform:translateY(0) rotate(0deg)}
  33%{transform:translateY(-30px) rotate(5deg)}
  66%{transform:translateY(15px) rotate(-3deg)}
}
/* Helicopter SVG */
.heli{font-size:80px;animation:floatObj 18s ease-in-out infinite,moveHeli 40s linear infinite}
@keyframes moveHeli{0%{left:-10%}100%{left:110%}}
.gun{font-size:60px;animation:floatObj 22s ease-in-out infinite 3s}
.walkie{font-size:45px;animation:floatObj 16s ease-in-out infinite 6s}
.device{font-size:40px;animation:floatObj 25s ease-in-out infinite 9s}

/* ============================
   ACCESS SCREEN
   ============================ */
#access-screen{
  position:fixed;inset:0;z-index:1000;
  background:var(--bg-black);
  display:flex;flex-direction:column;
  align-items:center;justify-content:center;
  overflow:hidden;
}
.access-grid{
  position:absolute;inset:0;
  background-image:
    linear-gradient(rgba(176,38,255,0.08) 1px,transparent 1px),
    linear-gradient(90deg,rgba(176,38,255,0.08) 1px,transparent 1px);
  background-size:40px 40px;
  animation:gridScan 2s ease-out forwards;
}
@keyframes gridScan{
  0%{opacity:0;transform:scale(1.1)}
  100%{opacity:1;transform:scale(1)}
}
.access-corner{
  position:absolute;width:60px;height:60px;
  border-color:var(--neon-purple);border-style:solid;
  animation:cornerPulse 2s ease-in-out infinite;
}
.ac-tl{top:20px;left:20px;border-width:2px 0 0 2px}
.ac-tr{top:20px;right:20px;border-width:2px 2px 0 0}
.ac-bl{bottom:20px;left:20px;border-width:0 0 2px 2px}
.ac-br{bottom:20px;right:20px;border-width:0 2px 2px 0}
@keyframes cornerPulse{
  0%,100%{box-shadow:inset 0 0 8px var(--neon-glow)}
  50%{box-shadow:inset 0 0 20px var(--neon-glow),0 0 15px var(--neon-glow)}
}
.access-title{
  font-family:var(--font-hud);font-size:clamp(1rem,3vw,1.4rem);
  color:var(--neon-purple);letter-spacing:8px;
  text-transform:uppercase;margin-bottom:10px;
  animation:glitchText 4s infinite;
}
.access-subtitle{
  font-family:var(--font-mono);font-size:clamp(0.7rem,2vw,0.9rem);
  color:var(--text-dim);letter-spacing:4px;margin-bottom:40px;
  animation:typewriter 2s steps(30) 0.5s both;overflow:hidden;white-space:nowrap;
}
@keyframes typewriter{
  from{width:0}to{width:100%}
}
.init-bars{width:min(400px,90vw);margin-bottom:30px}
.init-bar-row{
  display:flex;align-items:center;gap:10px;margin:6px 0;
  font-family:var(--font-mono);font-size:0.72rem;color:var(--text-dim);
}
.init-bar-label{width:160px;white-space:nowrap}
.init-bar-track{
  flex:1;height:3px;background:rgba(176,38,255,0.15);
  border-radius:2px;overflow:hidden;
}
.init-bar-fill{
  height:100%;background:linear-gradient(90deg,var(--neon-purple),var(--neon-soft));
  width:0%;border-radius:2px;
  box-shadow:0 0 6px var(--neon-purple);
}
.init-status{color:var(--text-mono);font-size:0.65rem;width:55px;text-align:right}
.access-btn-wrap{margin-top:20px}
#enter-btn{
  font-family:var(--font-hud);font-size:0.9rem;
  letter-spacing:5px;text-transform:uppercase;
  padding:14px 48px;
  background:transparent;
  border:1.5px solid var(--neon-purple);
  color:var(--neon-soft);
  cursor:none;
  position:relative;overflow:hidden;
  clip-path:polygon(12px 0%,100% 0%,calc(100% - 12px) 100%,0% 100%);
  transition:color 0.3s,box-shadow 0.3s;
  display:none;
}
#enter-btn::before{
  content:'';position:absolute;inset:0;
  background:linear-gradient(135deg,rgba(176,38,255,0.1),rgba(208,112,255,0.15));
  transform:translateX(-100%);transition:transform 0.4s;
}
#enter-btn:hover{
  color:#fff;
  box-shadow:0 0 30px var(--neon-glow),0 0 60px rgba(176,38,255,0.2);
}
#enter-btn:hover::before{transform:translateX(0)}

/* ============================
   NAME INPUT
   ============================ */
.name-input-wrap{
  margin:20px 0;display:none;
  flex-direction:column;align-items:center;gap:12px;
}
.name-label{
  font-family:var(--font-mono);font-size:0.8rem;
  color:var(--text-dim);letter-spacing:3px;
}
#visitor-name{
  font-family:var(--font-mono);font-size:1rem;
  background:transparent;
  border:none;border-bottom:1.5px solid var(--neon-purple);
  color:var(--neon-soft);padding:8px 16px;
  text-align:center;letter-spacing:3px;
  outline:none;width:260px;
  transition:border-color 0.3s,box-shadow 0.3s;
}
#visitor-name:focus{
  border-color:var(--neon-soft);
  box-shadow:0 4px 20px rgba(176,38,255,0.3);
}
#visitor-name::placeholder{color:rgba(176,38,255,0.3);letter-spacing:2px}

/* ============================
   QUOTE REVEAL SCREEN
   ============================ */
#quote-screen{
  position:fixed;inset:0;z-index:900;
  background:#000;
  display:none;flex-direction:column;
  align-items:center;justify-content:center;
  overflow:hidden;
}
.quote-bg-lines{
  position:absolute;inset:0;
  background:repeating-linear-gradient(
    90deg,
    transparent,transparent 39px,
    rgba(176,38,255,0.04) 39px,rgba(176,38,255,0.04) 40px
  );
}
.quote-text{
  font-family:var(--font-hud);
  font-size:clamp(1.2rem,4vw,2.2rem);
  color:var(--neon-soft);
  text-align:center;
  max-width:700px;
  padding:0 30px;
  line-height:1.5;
  letter-spacing:3px;
  text-shadow:0 0 30px var(--neon-purple),0 0 60px rgba(176,38,255,0.4);
  opacity:0;
  animation:quoteReveal 3s ease 0.5s forwards;
}
@keyframes quoteReveal{
  0%{opacity:0;transform:scale(0.9) translateY(20px)}
  30%{opacity:1;transform:scale(1) translateY(0)}
  80%{opacity:1}
  100%{opacity:0}
}
.quote-continue{
  font-family:var(--font-mono);font-size:0.7rem;
  color:var(--text-dim);letter-spacing:4px;
  margin-top:30px;
  opacity:0;animation:fadeIn 1s ease 3.5s forwards;
  text-transform:uppercase;
}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}

/* ============================
   MAIN SITE
   ============================ */
#main-site{display:none}

/* ============================
   NAV
   ============================ */
nav{
  position:fixed;top:0;left:0;right:0;z-index:500;
  padding:16px clamp(16px,4vw,60px);
  display:flex;align-items:center;justify-content:space-between;
  background:rgba(2,2,5,0.8);
  backdrop-filter:blur(12px);
  border-bottom:1px solid rgba(176,38,255,0.15);
}
.nav-logo{
  font-family:var(--font-hud);font-size:clamp(0.75rem,2vw,1rem);
  letter-spacing:4px;color:var(--neon-purple);
  text-decoration:none;
}
.nav-logo span{color:var(--neon-soft)}
.nav-links{
  display:flex;gap:clamp(12px,2.5vw,32px);align-items:center;
  list-style:none;
}
.nav-links a{
  font-family:var(--font-mono);font-size:clamp(0.65rem,1.4vw,0.8rem);
  letter-spacing:2px;text-transform:uppercase;
  color:var(--text-dim);text-decoration:none;
  position:relative;transition:color 0.3s;
  padding-bottom:2px;
}
.nav-links a::after{
  content:'';position:absolute;bottom:0;left:0;width:0;height:1px;
  background:var(--neon-purple);
  transition:width 0.3s;
  box-shadow:0 0 5px var(--neon-purple);
}
.nav-links a:hover{color:var(--neon-soft)}
.nav-links a:hover::after{width:100%}
.hamburger{display:none;flex-direction:column;gap:5px;cursor:none;padding:6px}
.hamburger span{
  display:block;width:24px;height:2px;
  background:var(--neon-purple);
  transition:transform 0.3s,opacity 0.3s;
}
@media(max-width:680px){
  .nav-links{
    position:fixed;top:60px;right:0;width:220px;
    flex-direction:column;align-items:flex-end;
    padding:20px 24px;
    background:rgba(7,5,15,0.97);
    border-left:1px solid rgba(176,38,255,0.3);
    border-bottom:1px solid rgba(176,38,255,0.3);
    transform:translateX(100%);transition:transform 0.4s;
    z-index:499;
  }
  .nav-links.open{transform:translateX(0)}
  .hamburger{display:flex}
}

/* ============================
   SECTIONS SHARED
   ============================ */
section{
  min-height:100vh;padding:100px clamp(16px,6vw,120px) 80px;
  position:relative;z-index:10;
}
.section-tag{
  font-family:var(--font-mono);font-size:0.7rem;
  color:var(--neon-purple);letter-spacing:5px;
  text-transform:uppercase;margin-bottom:10px;
  display:flex;align-items:center;gap:10px;
}
.section-tag::before{
  content:'';width:30px;height:1px;
  background:var(--neon-purple);
  box-shadow:0 0 6px var(--neon-purple);
}
.section-title{
  font-family:var(--font-hud);
  font-size:clamp(1.8rem,5vw,3.5rem);
  font-weight:900;letter-spacing:4px;
  line-height:1.1;
  text-transform:uppercase;
  color:transparent;
  background:linear-gradient(135deg,#fff 30%,var(--neon-soft) 70%,var(--neon-purple) 100%);
  -webkit-background-clip:text;background-clip:text;
  margin-bottom:16px;
}

/* ============================
   HERO
   ============================ */
#hero{
  display:flex;flex-direction:column;
  justify-content:center;min-height:100vh;
  padding-top:80px;
  position:relative;overflow:hidden;
}
.hero-eyebrow{
  font-family:var(--font-mono);font-size:0.75rem;
  color:var(--neon-purple);letter-spacing:6px;
  text-transform:uppercase;margin-bottom:12px;
  opacity:0;animation:slideUp 0.8s ease 0.3s forwards;
}
.hero-name{
  font-family:var(--font-hud);
  font-size:clamp(2.5rem,9vw,7rem);
  font-weight:900;letter-spacing:6px;
  line-height:1;color:#fff;
  position:relative;
  opacity:0;animation:slideUp 0.8s ease 0.6s forwards;
}
.hero-name .glitch{
  position:relative;display:inline-block;
}
.hero-name .glitch::before,
.hero-name .glitch::after{
  content:attr(data-text);
  position:absolute;top:0;left:0;
  clip-path:polygon(0 0,100% 0,100% 35%,0 35%);
}
.hero-name .glitch::before{
  color:var(--accent-cyan);
  animation:glitch1 4s infinite;
  text-shadow:2px 0 var(--accent-cyan);
}
.hero-name .glitch::after{
  color:var(--accent-red);
  animation:glitch2 4s infinite 0.5s;
  clip-path:polygon(0 65%,100% 65%,100% 100%,0 100%);
  text-shadow:-2px 0 var(--accent-red);
}
@keyframes glitch1{
  0%,90%,100%{transform:translate(0);opacity:0}
  91%{transform:translate(-3px,1px);opacity:1}
  93%{transform:translate(3px,-1px);opacity:1}
  95%{transform:translate(-2px);opacity:0}
}
@keyframes glitch2{
  0%,88%,100%{transform:translate(0);opacity:0}
  89%{transform:translate(3px,2px);opacity:1}
  92%{transform:translate(-3px,-2px);opacity:1}
  94%{transform:translate(1px);opacity:0}
}
@keyframes glitchText{
  0%,94%,100%{text-shadow:none}
  95%{text-shadow:2px 0 var(--accent-cyan),-2px 0 var(--accent-red);transform:translate(-1px)}
  97%{text-shadow:-2px 0 var(--accent-cyan),2px 0 var(--accent-red);transform:translate(1px)}
}
.hero-tagline{
  font-family:var(--font-body);font-weight:300;
  font-size:clamp(0.8rem,2vw,1.1rem);
  color:var(--text-dim);max-width:680px;
  line-height:1.8;margin-top:20px;
  letter-spacing:1px;
  opacity:0;animation:slideUp 0.8s ease 1s forwards;
}
.hero-tagline em{color:var(--neon-soft);font-style:normal}
.hero-chips{
  display:flex;flex-wrap:wrap;gap:10px;margin-top:28px;
  opacity:0;animation:slideUp 0.8s ease 1.3s forwards;
}
.chip{
  font-family:var(--font-mono);font-size:0.68rem;
  letter-spacing:2px;padding:5px 14px;
  border:1px solid rgba(176,38,255,0.4);
  color:var(--text-dim);
  clip-path:polygon(8px 0%,100% 0%,calc(100% - 8px) 100%,0% 100%);
  background:rgba(176,38,255,0.05);
  transition:all 0.3s;
}
.chip:hover{
  border-color:var(--neon-purple);color:var(--neon-soft);
  background:rgba(176,38,255,0.12);
  box-shadow:0 0 12px var(--neon-glow);
}
.hero-cta{
  display:flex;flex-wrap:wrap;gap:16px;margin-top:36px;
  opacity:0;animation:slideUp 0.8s ease 1.6s forwards;
}
.btn-primary{
  font-family:var(--font-hud);font-size:0.8rem;
  letter-spacing:3px;text-transform:uppercase;
  padding:14px 36px;
  background:linear-gradient(135deg,rgba(176,38,255,0.2),rgba(208,112,255,0.1));
  border:1.5px solid var(--neon-purple);
  color:var(--neon-soft);cursor:none;
  text-decoration:none;
  clip-path:polygon(12px 0%,100% 0%,calc(100% - 12px) 100%,0% 100%);
  transition:all 0.3s;position:relative;overflow:hidden;
  box-shadow:0 0 15px var(--neon-glow);
}
.btn-primary:hover{
  background:linear-gradient(135deg,rgba(176,38,255,0.4),rgba(208,112,255,0.25));
  box-shadow:0 0 30px var(--neon-glow),0 0 60px rgba(176,38,255,0.2);
  color:#fff;
}
.btn-secondary{
  font-family:var(--font-mono);font-size:0.8rem;
  letter-spacing:3px;text-transform:uppercase;
  padding:13px 30px;
  background:transparent;
  border:1px solid rgba(176,38,255,0.3);
  color:var(--text-dim);cursor:none;
  text-decoration:none;
  transition:all 0.3s;
}
.btn-secondary:hover{
  border-color:var(--neon-purple);color:var(--neon-soft);
}
.hero-status{
  position:absolute;bottom:40px;right:clamp(16px,6vw,120px);
  font-family:var(--font-mono);font-size:0.65rem;
  color:var(--text-dim);letter-spacing:2px;
  display:flex;align-items:center;gap:8px;
}
.status-dot{
  width:6px;height:6px;
  background:var(--text-mono);
  border-radius:50%;
  box-shadow:0 0 8px var(--text-mono);
  animation:blink 1.5s ease-in-out infinite;
}
@keyframes blink{0%,100%{opacity:1}50%{opacity:0.2}}
@keyframes slideUp{
  from{opacity:0;transform:translateY(30px)}
  to{opacity:1;transform:translateY(0)}
}

/* ============================
   HERO PROFILE IMAGE
   ============================ */
.hero-photo-frame{
  position:absolute;right:clamp(16px,8vw,140px);top:50%;
  transform:translateY(-50%);
  width:clamp(140px,15vw,200px);
  height:clamp(140px,15vw,200px);
  opacity:0;animation:slideUp 1s ease 1s forwards;
}
.hero-photo-frame::before{
  content:'';position:absolute;inset:-6px;
  border:1px solid rgba(176,38,255,0.4);
  clip-path:polygon(20px 0%,100% 0%,100% calc(100% - 20px),calc(100% - 20px) 100%,0% 100%,0% 20px);
  animation:photoBorder 4s ease-in-out infinite;
}
@keyframes photoBorder{
  0%,100%{box-shadow:inset 0 0 20px var(--neon-glow)}
  50%{box-shadow:inset 0 0 40px rgba(176,38,255,0.5),0 0 30px var(--neon-glow)}
}
.hero-photo-frame img,.hero-photo-placeholder{
  width:100%;height:100%;
  object-fit:cover;
  clip-path:polygon(20px 0%,100% 0%,100% calc(100% - 20px),calc(100% - 20px) 100%,0% 100%,0% 20px);
}
.hero-photo-placeholder{
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  background:rgba(176,38,255,0.05);
  border:1px solid rgba(176,38,255,0.2);
  font-family:var(--font-mono);font-size:0.6rem;
  color:var(--text-dim);letter-spacing:2px;text-align:center;gap:8px;
}
.photo-icon{font-size:2rem}
.hero-photo-tag{
  position:absolute;bottom:-28px;right:0;left:0;
  font-family:var(--font-mono);font-size:0.6rem;
  color:var(--neon-purple);letter-spacing:3px;text-align:center;
}
@media(max-width:900px){.hero-photo-frame{display:none}}

/* ============================
   ABOUT (OPERATIVE PROFILE)
   ============================ */
#about{background:linear-gradient(180deg,var(--bg-black),var(--bg-dark))}
.about-grid{
  display:grid;grid-template-columns:1fr 1fr;
  gap:60px;margin-top:50px;align-items:start;
}
@media(max-width:800px){.about-grid{grid-template-columns:1fr;gap:40px}}

/* Hand hover card */
.hand-container{
  position:relative;display:flex;
  align-items:center;justify-content:center;
  min-height:360px;
}
.hand-svg-wrap{
  position:relative;cursor:none;
}
.hand-svg-wrap svg{
  width:clamp(180px,30vw,260px);
  filter:drop-shadow(0 0 12px var(--neon-glow));
  transition:filter 0.3s;
}
.hand-svg-wrap:hover svg{
  filter:drop-shadow(0 0 25px rgba(176,38,255,0.6));
}
.finger-zone{
  position:absolute;cursor:none;
}
.finger-tooltip{
  position:absolute;
  background:rgba(7,5,15,0.97);
  border:1px solid var(--neon-purple);
  padding:12px 16px;min-width:180px;
  font-family:var(--font-mono);font-size:0.7rem;
  color:var(--text-main);line-height:1.6;
  pointer-events:none;z-index:100;
  opacity:0;transform:scale(0.9) translateY(4px);
  transition:opacity 0.25s,transform 0.25s;
  clip-path:polygon(8px 0%,100% 0%,100% calc(100% - 8px),calc(100% - 8px) 100%,0% 100%,0% 8px);
  box-shadow:0 0 20px var(--neon-glow),inset 0 0 20px rgba(176,38,255,0.05);
  white-space:nowrap;
}
.finger-zone:hover .finger-tooltip{
  opacity:1;transform:scale(1) translateY(0);
}
.tooltip-title{
  display:block;color:var(--neon-soft);font-size:0.8rem;
  letter-spacing:2px;margin-bottom:4px;font-weight:bold;
}

/* About text */
.about-text-side{display:flex;flex-direction:column;gap:24px}
.about-bio{
  font-size:clamp(0.85rem,1.8vw,1rem);
  line-height:1.9;color:var(--text-dim);
}
.about-bio strong{color:var(--neon-soft)}
.about-stats{
  display:grid;grid-template-columns:1fr 1fr;gap:16px;
}
.stat-card{
  padding:16px;
  border:1px solid rgba(176,38,255,0.2);
  background:rgba(176,38,255,0.04);
  clip-path:polygon(10px 0%,100% 0%,100% calc(100% - 10px),calc(100% - 10px) 100%,0% 100%,0% 10px);
  transition:all 0.3s;
}
.stat-card:hover{
  border-color:var(--neon-purple);
  background:rgba(176,38,255,0.08);
  box-shadow:0 0 20px var(--neon-glow);
}
.stat-num{
  font-family:var(--font-hud);font-size:1.6rem;
  color:var(--neon-soft);font-weight:900;
}
.stat-label{
  font-family:var(--font-mono);font-size:0.65rem;
  color:var(--text-dim);letter-spacing:2px;
  text-transform:uppercase;margin-top:4px;
}

/* ============================
   TIMELINE
   ============================ */
.timeline{position:relative;margin-top:20px;padding-left:30px}
.timeline::before{
  content:'';position:absolute;left:0;top:8px;bottom:8px;
  width:1px;
  background:linear-gradient(180deg,var(--neon-purple),rgba(176,38,255,0.1));
  box-shadow:0 0 6px var(--neon-purple);
}
.tl-item{position:relative;margin-bottom:28px;opacity:0;transform:translateX(-20px);transition:all 0.5s}
.tl-item.visible{opacity:1;transform:translateX(0)}
.tl-dot{
  position:absolute;left:-33px;top:8px;
  width:8px;height:8px;
  background:var(--neon-purple);
  border-radius:50%;
  box-shadow:0 0 10px var(--neon-purple),0 0 20px var(--neon-glow);
}
.tl-year{
  font-family:var(--font-mono);font-size:0.65rem;
  color:var(--neon-purple);letter-spacing:3px;margin-bottom:4px;
}
.tl-title{
  font-family:var(--font-hud);font-size:0.85rem;
  color:var(--text-main);letter-spacing:2px;margin-bottom:4px;
}
.tl-desc{
  font-family:var(--font-body);font-size:0.8rem;
  color:var(--text-dim);line-height:1.6;
}

/* ============================
   TABS (OPS PANEL)
   ============================ */
.tabs-wrap{margin-top:16px}
.tab-btns{
  display:flex;flex-wrap:wrap;gap:2px;margin-bottom:24px;
  border-bottom:1px solid rgba(176,38,255,0.2);
}
.tab-btn{
  font-family:var(--font-mono);font-size:0.72rem;
  letter-spacing:2px;text-transform:uppercase;
  padding:10px 20px;background:transparent;
  border:none;color:var(--text-dim);cursor:none;
  position:relative;transition:color 0.3s;
  border-top:2px solid transparent;
  border-right:1px solid rgba(176,38,255,0.15);
}
.tab-btn::after{
  content:'';position:absolute;bottom:-1px;left:0;right:0;
  height:2px;background:var(--neon-purple);
  transform:scaleX(0);transition:transform 0.3s;
  box-shadow:0 0 8px var(--neon-purple);
}
.tab-btn.active{color:var(--neon-soft)}
.tab-btn.active::after{transform:scaleX(1)}
.tab-btn:hover{color:var(--text-main)}
.tab-panel{display:none}
.tab-panel.active{display:block;animation:fadeSlide 0.4s ease forwards}
@keyframes fadeSlide{
  from{opacity:0;transform:translateY(10px)}
  to{opacity:1;transform:translateY(0)}
}

/* ============================
   INTERESTS GRID
   ============================ */
.interests-grid{
  display:grid;
  grid-template-columns:repeat(auto-fill,minmax(180px,1fr));
  gap:16px;
}
.interest-card{
  padding:20px;
  border:1px solid rgba(176,38,255,0.2);
  background:rgba(176,38,255,0.03);
  transition:all 0.35s;
  clip-path:polygon(14px 0%,100% 0%,100% calc(100% - 14px),calc(100% - 14px) 100%,0% 100%,0% 14px);
}
.interest-card:hover{
  border-color:var(--neon-purple);
  background:rgba(176,38,255,0.1);
  transform:translateY(-4px);
  box-shadow:0 8px 30px var(--neon-glow);
}
.int-icon{font-size:2rem;margin-bottom:10px;display:block}
.int-title{
  font-family:var(--font-hud);font-size:0.8rem;
  letter-spacing:2px;color:var(--neon-soft);margin-bottom:6px;
}
.int-desc{font-size:0.75rem;color:var(--text-dim);line-height:1.6}

/* ============================
   CURRENTLY WORKING ON
   ============================ */
.wip-list{display:flex;flex-direction:column;gap:12px}
.wip-item{
  display:flex;align-items:flex-start;gap:14px;
  padding:16px;
  border:1px solid rgba(176,38,255,0.15);
  background:rgba(176,38,255,0.03);
  transition:all 0.3s;
}
.wip-item:hover{
  border-color:rgba(176,38,255,0.5);
  background:rgba(176,38,255,0.07);
  transform:translateX(6px);
}
.wip-badge{
  font-family:var(--font-mono);font-size:0.6rem;
  letter-spacing:2px;padding:3px 8px;
  background:rgba(176,38,255,0.15);
  border:1px solid rgba(176,38,255,0.4);
  color:var(--neon-soft);white-space:nowrap;
  flex-shrink:0;margin-top:2px;
}
.wip-text{font-size:0.82rem;color:var(--text-dim);line-height:1.6}
.wip-text strong{color:var(--text-main);font-family:var(--font-hud);font-size:0.78rem;letter-spacing:1px}

/* ============================
   CODING JOURNEY (GITHUB)
   ============================ */
#coding{background:var(--bg-dark)}
.github-panel{
  margin-top:40px;
  border:1px solid rgba(176,38,255,0.2);
  background:rgba(176,38,255,0.03);
  padding:30px;
  clip-path:polygon(20px 0%,100% 0%,100% calc(100% - 20px),calc(100% - 20px) 100%,0% 100%,0% 20px);
}
.gh-header{
  display:flex;align-items:center;gap:16px;margin-bottom:24px;
  flex-wrap:wrap;
}
.gh-avatar{
  width:60px;height:60px;
  border-radius:50%;
  border:2px solid var(--neon-purple);
  box-shadow:0 0 15px var(--neon-glow);
}
.gh-info{flex:1}
.gh-username{
  font-family:var(--font-hud);font-size:1.1rem;
  color:var(--neon-soft);letter-spacing:3px;
}
.gh-bio{font-family:var(--font-mono);font-size:0.72rem;color:var(--text-dim);margin-top:4px}
.gh-stats{
  display:grid;
  grid-template-columns:repeat(auto-fill,minmax(140px,1fr));
  gap:12px;margin-bottom:24px;
}
.gh-stat{
  padding:14px;
  border:1px solid rgba(176,38,255,0.15);
  background:rgba(176,38,255,0.04);
  text-align:center;
}
.gh-stat-num{
  font-family:var(--font-hud);font-size:1.5rem;
  color:var(--neon-soft);
}
.gh-stat-label{
  font-family:var(--font-mono);font-size:0.62rem;
  color:var(--text-dim);letter-spacing:2px;margin-top:4px;
}
.gh-repos{display:flex;flex-direction:column;gap:10px}
.repo-card{
  padding:14px 18px;
  border:1px solid rgba(176,38,255,0.15);
  background:rgba(176,38,255,0.03);
  display:flex;justify-content:space-between;
  align-items:flex-start;flex-wrap:wrap;gap:10px;
  transition:all 0.3s;cursor:none;
  text-decoration:none;
}
.repo-card:hover{
  border-color:var(--neon-purple);
  background:rgba(176,38,255,0.08);
  transform:translateX(6px);
}
.repo-name{
  font-family:var(--font-mono);font-size:0.82rem;
  color:var(--neon-soft);letter-spacing:2px;
}
.repo-desc{
  font-size:0.75rem;color:var(--text-dim);
  margin-top:4px;line-height:1.5;
}
.repo-lang{
  font-family:var(--font-mono);font-size:0.65rem;
  color:var(--neon-purple);letter-spacing:2px;
  display:flex;align-items:center;gap:5px;
  white-space:nowrap;
}
.lang-dot{width:8px;height:8px;border-radius:50%;background:var(--neon-purple);box-shadow:0 0 6px var(--neon-purple)}
.gh-cta{
  margin-top:20px;display:flex;justify-content:center;
}
.contribution-wrap{
  margin-top:20px;
  padding:16px;
  border:1px solid rgba(176,38,255,0.1);
  background:rgba(0,0,0,0.3);
  overflow:hidden;
}
.contribution-wrap img{
  width:100%;
  filter:hue-rotate(220deg) saturate(1.5) brightness(0.85);
  opacity:0.9;
}

/* ============================
   HOBBIES (LOADOUT / ARCHIVE)
   ============================ */
#hobbies{background:var(--bg-black)}
.hobby-tabs .tab-btn{font-size:0.65rem}

/* Photo Archive */
.photo-grid{
  display:grid;
  grid-template-columns:repeat(auto-fill,minmax(200px,1fr));
  gap:12px;margin-top:12px;
}
.photo-slot{
  aspect-ratio:1;
  border:1px solid rgba(176,38,255,0.2);
  background:rgba(176,38,255,0.04);
  display:flex;flex-direction:column;
  align-items:center;justify-content:center;
  gap:8px;cursor:none;
  transition:all 0.3s;
  position:relative;overflow:hidden;
  clip-path:polygon(10px 0%,100% 0%,100% calc(100% - 10px),calc(100% - 10px) 100%,0% 100%,0% 10px);
}
.photo-slot img{
  width:100%;height:100%;object-fit:cover;position:absolute;inset:0;
  clip-path:polygon(10px 0%,100% 0%,100% calc(100% - 10px),calc(100% - 10px) 100%,0% 100%,0% 10px);
}
.photo-slot:hover{
  border-color:var(--neon-purple);
  box-shadow:0 0 20px var(--neon-glow);
}
.photo-add{
  font-family:var(--font-mono);font-size:0.65rem;
  color:rgba(176,38,255,0.5);letter-spacing:2px;text-align:center;
}
.photo-add-icon{font-size:1.5rem;color:rgba(176,38,255,0.3)}

/* Music */
.playlist-section{display:flex;flex-direction:column;gap:28px;margin-top:12px}
.playlist-card{
  border:1px solid rgba(176,38,255,0.2);
  background:rgba(176,38,255,0.03);
  padding:24px;
  clip-path:polygon(14px 0%,100% 0%,100% calc(100% - 14px),calc(100% - 14px) 100%,0% 100%,0% 14px);
}
.playlist-header{
  display:flex;align-items:center;justify-content:space-between;
  margin-bottom:16px;flex-wrap:wrap;gap:10px;
}
.playlist-name{
  font-family:var(--font-hud);font-size:1rem;
  color:var(--neon-soft);letter-spacing:3px;
}
.playlist-badge{
  font-family:var(--font-mono);font-size:0.62rem;
  letter-spacing:2px;padding:4px 10px;
  border:1px solid rgba(176,38,255,0.4);
  color:var(--neon-purple);
  background:rgba(176,38,255,0.08);
}
.track-list{display:flex;flex-direction:column;gap:4px}
.track{
  display:flex;align-items:center;gap:12px;
  padding:8px 12px;
  transition:background 0.2s;border-radius:2px;
}
.track:hover{background:rgba(176,38,255,0.08)}
.track-num{
  font-family:var(--font-mono);font-size:0.65rem;
  color:var(--text-dim);width:20px;text-align:right;
}
.track-info{flex:1}
.track-name{font-size:0.82rem;color:var(--text-main)}
.track-artist{font-family:var(--font-mono);font-size:0.68rem;color:var(--text-dim)}
.track-dur{font-family:var(--font-mono);font-size:0.68rem;color:var(--text-dim)}
.track-play-btn{
  width:28px;height:28px;
  background:rgba(176,38,255,0.15);
  border:1px solid rgba(176,38,255,0.3);
  border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  cursor:none;color:var(--neon-soft);font-size:0.6rem;
  transition:all 0.3s;flex-shrink:0;
}
.track-play-btn:hover{
  background:var(--neon-purple);
  box-shadow:0 0 12px var(--neon-glow);
}

/* Add playlist link */
.playlist-link{
  display:flex;align-items:center;gap:10px;
  padding:10px 14px;margin-top:12px;
  border:1px dashed rgba(176,38,255,0.25);
  color:var(--text-dim);font-family:var(--font-mono);
  font-size:0.7rem;letter-spacing:2px;
  cursor:none;transition:all 0.3s;text-decoration:none;
}
.playlist-link:hover{
  border-color:var(--neon-purple);
  color:var(--neon-soft);
}

/* ============================
   CONTACT (TRANSMISSION)
   ============================ */
#contact{background:var(--bg-dark)}
.contact-grid{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:50px;margin-top:40px;
  align-items:start;
}
@media(max-width:800px){.contact-grid{grid-template-columns:1fr;gap:30px}}
.contact-info{display:flex;flex-direction:column;gap:16px}
.contact-line{
  display:flex;align-items:flex-start;gap:16px;
  padding:16px;
  border:1px solid rgba(176,38,255,0.15);
  background:rgba(176,38,255,0.03);
  transition:all 0.3s;
  text-decoration:none;
  clip-path:polygon(8px 0%,100% 0%,100% calc(100% - 8px),calc(100% - 8px) 100%,0% 100%,0% 8px);
}
.contact-line:hover{
  border-color:var(--neon-purple);
  background:rgba(176,38,255,0.07);
  transform:translateX(6px);
  box-shadow:0 0 20px var(--neon-glow);
}
.contact-icon{
  font-size:1.3rem;flex-shrink:0;margin-top:2px;
}
.contact-type{
  font-family:var(--font-mono);font-size:0.62rem;
  letter-spacing:3px;color:var(--neon-purple);
  text-transform:uppercase;margin-bottom:2px;
}
.contact-value{
  font-size:0.85rem;color:var(--text-main);
}

/* Contact Form */
.contact-form{display:flex;flex-direction:column;gap:16px}
.form-field{display:flex;flex-direction:column;gap:6px}
.form-label{
  font-family:var(--font-mono);font-size:0.65rem;
  color:var(--neon-purple);letter-spacing:3px;text-transform:uppercase;
}
.form-input,.form-textarea{
  background:rgba(176,38,255,0.04);
  border:1px solid rgba(176,38,255,0.2);
  color:var(--text-main);
  font-family:var(--font-mono);font-size:0.82rem;
  padding:12px 16px;outline:none;
  transition:border-color 0.3s,box-shadow 0.3s;
  clip-path:polygon(8px 0%,100% 0%,100% calc(100% - 8px),calc(100% - 8px) 100%,0% 100%,0% 8px);
}
.form-textarea{resize:vertical;min-height:110px}
.form-input:focus,.form-textarea:focus{
  border-color:var(--neon-purple);
  box-shadow:0 0 20px var(--neon-glow),inset 0 0 10px rgba(176,38,255,0.05);
}
.form-submit{
  font-family:var(--font-hud);font-size:0.8rem;
  letter-spacing:4px;text-transform:uppercase;
  padding:14px 32px;align-self:flex-start;
  background:linear-gradient(135deg,rgba(176,38,255,0.2),rgba(208,112,255,0.1));
  border:1.5px solid var(--neon-purple);
  color:var(--neon-soft);cursor:none;
  clip-path:polygon(12px 0%,100% 0%,calc(100% - 12px) 100%,0% 100%);
  transition:all 0.3s;
  box-shadow:0 0 15px var(--neon-glow);
}
.form-submit:hover{
  background:rgba(176,38,255,0.3);
  box-shadow:0 0 30px var(--neon-glow);color:#fff;
}
.form-note{
  font-family:var(--font-mono);font-size:0.65rem;
  color:var(--text-dim);letter-spacing:1px;margin-top:4px;
}
.form-note span{color:var(--neon-soft)}

/* ============================
   FOOTER
   ============================ */
footer{
  padding:40px clamp(16px,6vw,120px);
  border-top:1px solid rgba(176,38,255,0.15);
  display:flex;align-items:center;justify-content:space-between;
  flex-wrap:wrap;gap:16px;
  position:relative;z-index:10;
}
.footer-copy{
  font-family:var(--font-mono);font-size:0.65rem;
  color:var(--text-dim);letter-spacing:2px;
}
.footer-copy span{color:var(--neon-purple)}
.footer-links{
  display:flex;gap:20px;
}
.footer-links a{
  font-family:var(--font-mono);font-size:0.65rem;
  color:var(--text-dim);text-decoration:none;
  letter-spacing:2px;transition:color 0.3s;
}
.footer-links a:hover{color:var(--neon-soft)}

/* ============================
   NOTIFICATION TOAST
   ============================ */
#toast{
  position:fixed;bottom:30px;right:30px;z-index:9999;
  background:rgba(7,5,15,0.97);
  border:1px solid var(--neon-purple);
  padding:14px 20px;max-width:300px;
  font-family:var(--font-mono);font-size:0.72rem;
  color:var(--text-main);letter-spacing:1px;
  transform:translateY(100px);opacity:0;
  transition:all 0.4s;
  clip-path:polygon(10px 0%,100% 0%,100% calc(100% - 10px),calc(100% - 10px) 100%,0% 100%,0% 10px);
  box-shadow:0 0 30px var(--neon-glow);
}
#toast.show{transform:translateY(0);opacity:1}
#toast .toast-title{color:var(--neon-soft);font-weight:bold;margin-bottom:4px}

/* ============================
   SCROLL REVEAL
   ============================ */
.reveal{opacity:0;transform:translateY(30px);transition:all 0.7s ease}
.reveal.visible{opacity:1;transform:translateY(0)}

/* ============================
   MISC
   ============================ */
.neon-line{
  width:100%;height:1px;
  background:linear-gradient(90deg,transparent,var(--neon-purple),transparent);
  margin:40px 0;
  box-shadow:0 0 8px var(--neon-purple);
}
.hud-corner{
  position:absolute;width:40px;height:40px;
  border-color:rgba(176,38,255,0.3);border-style:solid;
}
.hud-tl{top:0;left:0;border-width:1px 0 0 1px}
.hud-tr{top:0;right:0;border-width:1px 1px 0 0}
.hud-bl{bottom:0;left:0;border-width:0 0 1px 1px}
.hud-br{bottom:0;right:0;border-width:0 1px 1px 0}

/* Particle canvas */
#particle-canvas{position:fixed;inset:0;pointer-events:none;z-index:2;opacity:0.4}
